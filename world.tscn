[gd_scene load_steps=2 format=3 uid="uid://mgp02mkor0at"]

[sub_resource type="GDScript" id="GDScript_citygen"]
script/source = "extends Node3D

const WORLD_SIZE = 2000
const ROAD_MAJOR_INTERVAL = 200
const ROAD_MINOR_INTERVAL = 50
const ROAD_WIDTH = 10.0
const ROAD_HEIGHT = 0.2
const SIDEWALK = 6.0
const BUILDING_HEIGHT_MIN = 5.0
const BUILDING_HEIGHT_MAX = 40.0

var rng = RandomNumberGenerator.new()

func _ready():
	rng.seed = 12345

	# Ground (green grass)
	var ground = CSGBox3D.new()
	ground.size = Vector3(WORLD_SIZE, 0.1, WORLD_SIZE)
	ground.material = _make_material(Color(0.25, 0.55, 0.2))
	ground.use_collision = true
	ground.transform.origin.y = -0.05
	add_child(ground)

	# Lighting
	var dir_light = DirectionalLight3D.new()
	dir_light.transform = Transform3D().looking_at(Vector3(-0.5, -1, -0.3), Vector3.UP)
	add_child(dir_light)

	var env = WorldEnvironment.new()
	env.environment = Environment.new()
	env.environment.ambient_light_source = 2
	env.environment.ambient_light_color = Color.WHITE
	add_child(env)

	# Road network
	var road_mat = _make_material(Color(0.25, 0.25, 0.25))
	for z in range(-WORLD_SIZE/2, WORLD_SIZE/2 + 1, ROAD_MAJOR_INTERVAL):
		_add_road(Vector3(0, ROAD_HEIGHT/2, z), Vector3(WORLD_SIZE, ROAD_HEIGHT, ROAD_WIDTH), road_mat)
	for x in range(-WORLD_SIZE/2, WORLD_SIZE/2 + 1, ROAD_MAJOR_INTERVAL):
		_add_road(Vector3(x, ROAD_HEIGHT/2, 0), Vector3(ROAD_WIDTH, ROAD_HEIGHT, WORLD_SIZE), road_mat)

	# Buildings
	var building_mats = [
		_make_material(Color(0.7, 0.65, 0.55)),
		_make_material(Color(0.55, 0.55, 0.65)),
		_make_material(Color(0.8, 0.75, 0.6)),
		_make_material(Color(0.9, 0.85, 0.75)),
		_make_material(Color(0.6, 0.6, 0.7))
	]

	var block_size = ROAD_MAJOR_INTERVAL
	var half_world = WORLD_SIZE / 2
	var plots_per_side = 4
	var plot_size = block_size / plots_per_side

	for cx in range(-half_world + block_size/2, half_world - block_size/2 + 1, block_size):
		for cz in range(-half_world + block_size/2, half_world - block_size/2 + 1, block_size):
			# Subdivide block
			for i in range(plots_per_side):
				for j in range(plots_per_side):
					var px = cx - block_size/2 + plot_size/2 + i * plot_size
					var pz = cz - block_size/2 + plot_size/2 + j * plot_size
					# Skip if too close to roads (sidewalk)
					var dist_x = abs(px - cx)
					var dist_z = abs(pz - cz)
					if dist_x < SIDEWALK + ROAD_WIDTH/2 or dist_z < SIDEWALK + ROAD_WIDTH/2:
						continue
					if rng.randf() < 0.65:
						var h = rng.randf_range(BUILDING_HEIGHT_MIN, BUILDING_HEIGHT_MAX)
						var w = rng.randf_range(plot_size * 0.4, plot_size * 0.7)
						var d = rng.randf_range(plot_size * 0.4, plot_size * 0.7)
						var mat = building_mats[rng.randi() % building_mats.size()]
						_add_building(Vector3(px, h/2 + ROAD_HEIGHT, pz), Vector3(w, h, d), mat)

	# Trees along sidewalks / open areas
	var trunk_mat = _make_material(Color(0.45, 0.25, 0.1))
	var leaves_mat = _make_material(Color(0.15, 0.45, 0.1))
	for x in range(-half_world, half_world, 15):
		for z in range(-half_world, half_world, 15):
			# Only place on grass (not inside roads)
			var on_road = false
			for rx in range(-half_world, half_world + 1, ROAD_MAJOR_INTERVAL):
				if abs(x - rx) < ROAD_WIDTH/2 or abs(z - rx) < ROAD_WIDTH/2:
					on_road = true
					break
			if not on_road and rng.randf() < 0.08:
				_add_tree(Vector3(x, ROAD_HEIGHT, z), trunk_mat, leaves_mat)

	# Player spawn point
	var player_scene = load(\"res://player.tscn\")
	var player = player_scene.instantiate()
	player.transform.origin = Vector3(0, 5, 0)
	add_child(player)

func _make_material(color: Color) -> StandardMaterial3D:
	var mat = StandardMaterial3D.new()
	mat.albedo_color = color
	return mat

func _add_road(position: Vector3, size: Vector3, material: Material):
	var body = StaticBody3D.new()
	body.transform.origin = position
	var shape = BoxShape3D.new()
	shape.size = size
	var col = CollisionShape3D.new()
	col.shape = shape
	body.add_child(col)

	var mesh_instance = MeshInstance3D.new()
	var box = BoxMesh.new()
	box.size = size
	mesh_instance.mesh = box
	mesh_instance.material_override = material
	body.add_child(mesh_instance)
	add_child(body)

func _add_building(position: Vector3, size: Vector3, material: Material):
	var body = StaticBody3D.new()
	body.transform.origin = position
	var shape = BoxShape3D.new()
	shape.size = size
	var col = CollisionShape3D.new()
	col.shape = shape
	body.add_child(col)

	var mesh_instance = MeshInstance3D.new()
	var box = BoxMesh.new()
	box.size = size
	mesh_instance.mesh = box
	mesh_instance.material_override = material
	body.add_child(mesh_instance)
	add_child(body)

func _add_tree(position: Vector3, trunk_material: Material, leaves_material: Material):
	var tree = Node3D.new()
	tree.transform.origin = position

	# Trunk
	var trunk_body = StaticBody3D.new()
	var trunk_shape = CylinderShape3D.new()
	trunk_shape.height = 2.0
	trunk_shape.radius = 0.2
	var trunk_col = CollisionShape3D.new()
	trunk_col.shape = trunk_shape
	trunk_body.add_child(trunk_col)

	var trunk_mesh = MeshInstance3D.new()
	var cylinder = CylinderMesh.new()
	cylinder.top_radius = 0.15
	cylinder.bottom_radius = 0.25
	cylinder.height = 2.0
	trunk_mesh.mesh = cylinder
	trunk_mesh.material_override = trunk_material
	trunk_body.add_child(trunk_mesh)
	trunk_body.transform.origin.y = 1.0
	tree.add_child(trunk_body)

	# Leaves (cone)
	var leaves_mesh = MeshInstance3D.new()
	var cone = ConeMesh.new()
	cone.top_radius = 0.0
	cone.bottom_radius = 1.5
	cone.height = 3.0
	leaves_mesh.mesh = cone
	leaves_mesh.material_override = leaves_material
	leaves_mesh.transform.origin.y = 2.8
	tree.add_child(leaves_mesh)

	add_child(tree)
"

[node name="Node3D" type="Node3D"]
script = SubResource("GDScript_citygen")
